# .env 파일의 템플릿. 이 파일을 복사해 .env를 만들고 실제 값을 채우세요.
# cp .env.example .env
SERVER_BASE_URL=https://api.example.com

# Google Maps API 키는 .env가 아니라 네이티브 설정 파일에 넣어야 합니다.
# - Android: android/app/src/main/AndroidManifest.xml 의 com.google.android.geo.API_KEY
# - iOS:     ios/Runner/AppDelegate.swift 의 GMSServices.provideAPIKey(...)
# 두 파일 모두 YOUR_GOOGLE_MAPS_API_KEY 자리에 실제 키를 붙여넣으세요.
